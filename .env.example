# Environment Variables untuk Absensi Sekolah
# Salin file ini menjadi .env dan isi semua nilai

# Key rahasia untuk akses halaman admin
ADMIN_KEY=ganti_dengan_key_rahasia

# Google Service Account JSON (satu baris, tanpa line break)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ID Google Spreadsheet (dari URL spreadsheet)
SPREADSHEET_ID=id_spreadsheet_google

# Koordinat lokasi sekolah
SCHOOL_LAT=-6.2984798916658065
SCHOOL_LNG=107.10119071620488

# Radius absensi dalam meter (default 200)
RADIUS_METER=200

# Nama sekolah (untuk label QR Code)
SCHOOL_NAME=Nama Sekolah Anda

# Vercel KV (otomatis terisi jika buat KV dari dashboard Vercel)
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=token...
