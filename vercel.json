{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "public/*", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/student.js", "dest": "/public/student.js" },
    { "src": "/admin.js", "dest": "/public/admin.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
